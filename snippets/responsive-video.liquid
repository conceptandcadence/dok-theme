<div
  class='video-html-wrapper {{ classes }}'
  data-aspect='{{ video.aspect_ratio }}'
  style="background-image: url('{{  video.preview_image | img_url: '600x' }}'); background-size: cover;"
>
  <video
    id='video-html-{{ video.id }}'
    class='video-html tw-w-full{% if autoplay %} autoplay{% endif %} {{ video_class }}'
    {% if autoplay %}
      preload='metadata'
    {% elsif defer %}
      preload='none'
    {% else %}
      preload='auto'
    {% endif %}
    {% if autoplay %}
      muted loop autoplay
    {% endif %}
    {% if muted %}
      muted loop
    {% endif %}
    playsinline
    webkit-playsinline='true'
    title='{{ title | default: video.alt | escape }}'
    poster='{{  video.preview_image | img_url: '600x' }}'
  >
    {%- for video_source in video.sources -%}
      {%- if video_source.mime_type == 'video/mp4' -%}
        <source type='{{ video_source.mime_type }}' src='{{ video_source.url }}'>
      {%- endif -%}
    {%- endfor -%}
    {%- for video_source in video.sources -%}
      {%- if video_source.mime_type != 'video/mp4' -%}
        <source type='{{ video_source.mime_type }}' src='{{ video_source.url }}'>
      {%- endif -%}
    {%- endfor -%}
    Your browser does not support the video tag.
  </video>
  {%- if autoplay -%}
    <script>
      (function () {
        var v = document.getElementById('video-html-{{ video.id }}');
        if (!v) return;
        var tryPlay = function () {
          var p = v.play();
          if (p && typeof p.catch === 'function') {
            p.catch(function () {
              v.muted = true;
              v.play().catch(function () {});
            });
          }
        };
        if (v.readyState >= 2) {
          tryPlay();
        } else {
          v.addEventListener('loadedmetadata', tryPlay, { once: true });
        }
        document.addEventListener(
          'visibilitychange',
          function () {
            if (!document.hidden && v.paused) tryPlay();
          },
          false
        );
      })();
    </script>
  {%- endif -%}
</div>

{% assign video = null %}
{% assign classes = null %}
{% assign defer = null %}
{% assign title = null %}
{% assign autoplay = null %}
{% assign muted = null %}
