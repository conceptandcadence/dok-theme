{% comment %}
  Section: Paddle-DOK Landing Page
  File name: sections/paddle-dok-landing.liquid
{% endcomment %}

{% assign paddle_product = all_products[section.settings.product] %}
{% assign product_url = section.settings.product_url | default: '/products/paddle-dok' %}
{% assign cta_url = product_url %}
{% if section.settings.cta_behavior == 'anchor' %}
  {% assign cta_url = '#shop-paddle-dok' %}
{% endif %}

<section class="pdok-landing" data-section-id="{{ section.id }}">
  <style>
    #shopify-section-{{ section.id }} .pdok-landing {
      --pdok-ink: {{ section.settings.text_color }};
      --pdok-muted: {{ section.settings.muted_text_color }};
      --pdok-cream: {{ section.settings.background_color }};
      --pdok-card: {{ section.settings.card_color }};
      --pdok-accent: {{ section.settings.accent_color }};
      --pdok-button: {{ section.settings.button_color }};
      --pdok-button-text: {{ section.settings.button_text_color }};
      --pdok-border: rgba(17, 17, 17, 0.12);
      background: var(--pdok-cream);
      color: var(--pdok-ink);
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .pdok-container {
      max-width: 1180px;
      margin: 0 auto;
      padding: 0 22px;
    }

    #shopify-section-{{ section.id }} .pdok-section {
      padding: 72px 0;
    }

    #shopify-section-{{ section.id }} .pdok-eyebrow {
      margin: 0 0 12px;
      font-size: 12px;
      letter-spacing: .14em;
      text-transform: uppercase;
      font-weight: 800;
      color: var(--pdok-muted);
    }

    #shopify-section-{{ section.id }} .pdok-h1,
    #shopify-section-{{ section.id }} .pdok-h2,
    #shopify-section-{{ section.id }} .pdok-h3 {
      margin: 0;
      line-height: .98;
      letter-spacing: -0.035em;
      color: var(--pdok-ink);
    }

    #shopify-section-{{ section.id }} .pdok-h1 {
      font-size: clamp(42px, 6vw, 78px);
      max-width: 720px;
    }

    #shopify-section-{{ section.id }} .pdok-h2 {
      font-size: clamp(34px, 4.7vw, 64px);
      max-width: 850px;
    }

    #shopify-section-{{ section.id }} .pdok-h3 {
      font-size: clamp(22px, 2.2vw, 32px);
      line-height: 1.05;
    }

    #shopify-section-{{ section.id }} .pdok-p {
      margin: 0;
      color: var(--pdok-muted);
      font-size: clamp(16px, 1.4vw, 19px);
      line-height: 1.58;
    }

    #shopify-section-{{ section.id }} .pdok-btn {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 52px;
      padding: 15px 28px;
      border-radius: 999px;
      background: var(--pdok-button);
      color: var(--pdok-button-text);
      text-decoration: none;
      font-weight: 800;
      font-size: 15px;
      line-height: 1;
      transition: transform .18s ease, opacity .18s ease;
      border: none;
      cursor: pointer;
    }

    #shopify-section-{{ section.id }} .pdok-btn:hover {
      transform: translateY(-1px);
      opacity: .92;
    }

    #shopify-section-{{ section.id }} .pdok-btn-secondary {
      background: transparent;
      color: var(--pdok-ink);
      border: 1px solid var(--pdok-border);
    }

    #shopify-section-{{ section.id }} .pdok-hero-link {
      display: inline-flex;
      align-items: center;
      min-height: 52px;
      color: #fff;
      text-decoration: none;
      font-weight: 850;
      font-size: 15px;
      line-height: 1;
      opacity: .92;
      border-bottom: 1px solid rgba(255,255,255,.55);
      transition: opacity .18s ease, transform .18s ease;
    }

    #shopify-section-{{ section.id }} .pdok-hero-link:hover {
      opacity: 1;
      transform: translateX(2px);
    }

    #shopify-section-{{ section.id }} .pdok-img,
    #shopify-section-{{ section.id }} .pdok-placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      background: #e9dfce;
    }

    #shopify-section-{{ section.id }} .pdok-placeholder {
      min-height: 320px;
      border-radius: inherit;
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(17,17,17,.45);
      font-weight: 800;
      text-align: center;
      padding: 24px;
    }

    /* HERO */
    #shopify-section-{{ section.id }} .pdok-hero {
      min-height: 760px;
      position: relative;
      display: flex;
      align-items: end;
      isolation: isolate;
      background: #111;
    }

    #shopify-section-{{ section.id }} .pdok-hero-media {
      position: absolute;
      inset: 0;
      z-index: -2;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .pdok-hero-media picture {
      display: block;
      width: 100%;
      height: 100%;
    }

    #shopify-section-{{ section.id }} .pdok-hero-media .pdok-img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center bottom;
      display: block;
    }

    #shopify-section-{{ section.id }} .pdok-hero-media:after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(0,0,0,.46), rgba(0,0,0,.12) 48%, rgba(0,0,0,.28)), linear-gradient(0deg, rgba(0,0,0,.58), rgba(0,0,0,0) 56%);
      z-index: 1;
    }

    #shopify-section-{{ section.id }} .pdok-hero-content {
      width: 100%;
      padding: 130px 0 64px;
      color: #fff;
    }

    #shopify-section-{{ section.id }} .pdok-hero .pdok-eyebrow,
    #shopify-section-{{ section.id }} .pdok-hero .pdok-h1,
    #shopify-section-{{ section.id }} .pdok-hero .pdok-p {
      color: #fff;
    }

    #shopify-section-{{ section.id }} .pdok-hero .pdok-p {
      max-width: 620px;
      opacity: .92;
      margin-top: 18px;
    }

    #shopify-section-{{ section.id }} .pdok-hero-copy-mobile,
    #shopify-section-{{ section.id }} .pdok-offer-mobile {
      display: none;
    }

    #shopify-section-{{ section.id }} .pdok-hero-eyebrow-desktop,
    #shopify-section-{{ section.id }} .pdok-hero-copy-desktop,
    #shopify-section-{{ section.id }} .pdok-offer-desktop {
      display: inline;
    }

    #shopify-section-{{ section.id }} .pdok-hero-copy-desktop {
      display: block;
    }

    #shopify-section-{{ section.id }} .pdok-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 28px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .pdok-offer-pill {
      display: inline-flex;
      width: fit-content;
      align-items: center;
      gap: 8px;
      margin-top: 18px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(255,255,255,.12);
      color: #fff;
      backdrop-filter: blur(8px);
      font-weight: 800;
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip {
      background: var(--pdok-cream);
      border-bottom: 1px solid var(--pdok-border);
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip-inner {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0;
      padding-top: 18px;
      padding-bottom: 18px;
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip-inner div {
      padding: 0 22px;
      border-right: 1px solid var(--pdok-border);
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip-inner div:first-child {
      padding-left: 0;
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip-inner div:last-child {
      border-right: 0;
      padding-right: 0;
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip-inner strong {
      display: block;
      font-size: 14px;
      line-height: 1.15;
      color: var(--pdok-ink);
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .pdok-proof-strip-inner span {
      display: block;
      margin-top: 4px;
      font-size: 13px;
      line-height: 1.25;
      color: var(--pdok-muted);
    }

    /* INTRO USE CASE */
    #shopify-section-{{ section.id }} .pdok-centered {
      text-align: center;
    }

    #shopify-section-{{ section.id }} .pdok-centered .pdok-h2,
    #shopify-section-{{ section.id }} .pdok-centered .pdok-p {
      margin-left: auto;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .pdok-centered .pdok-p {
      max-width: 760px;
      margin-top: 18px;
    }

    #shopify-section-{{ section.id }} .pdok-use-grid {
      margin-top: 38px;
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 16px;
    }

    #shopify-section-{{ section.id }} .pdok-use-card {
      min-height: 280px;
      border-radius: 26px;
      overflow: hidden;
      position: relative;
      background: var(--pdok-card);
      border: 1px solid var(--pdok-border);
    }

    #shopify-section-{{ section.id }} .pdok-use-card .pdok-img,
    #shopify-section-{{ section.id }} .pdok-use-card .pdok-placeholder {
      position: absolute;
      inset: 0;
      min-height: unset;
      border-radius: 0;
    }

    #shopify-section-{{ section.id }} .pdok-use-card:after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(0deg, rgba(0,0,0,.64), rgba(0,0,0,.08) 62%);
    }

    #shopify-section-{{ section.id }} .pdok-use-card-content {
      position: absolute;
      left: 18px;
      right: 18px;
      bottom: 18px;
      color: #fff;
      z-index: 2;
    }

    #shopify-section-{{ section.id }} .pdok-use-card-content h3 {
      margin: 0 0 6px;
      color: #fff;
      font-size: 22px;
      line-height: 1.05;
    }

    #shopify-section-{{ section.id }} .pdok-use-card-content p {
      margin: 0;
      color: rgba(255,255,255,.88);
      font-size: 14px;
      line-height: 1.35;
    }

    /* PRODUCT DETAILS DIAGRAM */
    #shopify-section-{{ section.id }} .pdok-callout {
      background: var(--pdok-card);
      border-top: 1px solid var(--pdok-border);
      border-bottom: 1px solid var(--pdok-border);
    }

    #shopify-section-{{ section.id }} .pdok-product-diagram {
      max-width: 1280px;
      margin: 44px auto 0;
    }

    #shopify-section-{{ section.id }} .pdok-product-diagram-img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 28px;
      box-shadow: 0 18px 48px rgba(17, 17, 17, 0.06);
    }

    #shopify-section-{{ section.id }} .pdok-product-diagram-mobile {
      display: none;
    }

    /* COMPARISON GRAPHIC */
    #shopify-section-{{ section.id }} .pdok-compare-graphic-wrap {
      margin-top: 42px;
      max-width: 1180px;
      margin-left: auto;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .pdok-compare-graphic-img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 30px;
      box-shadow: 0 22px 58px rgba(17, 17, 17, 0.06);
    }

    #shopify-section-{{ section.id }} .pdok-compare-graphic-mobile {
      display: none;
    }

    #shopify-section-{{ section.id }} .pdok-compare-placeholder {
      min-height: 520px;
      border-radius: 30px;
      background: #e9dfce;
      border: 1px solid var(--pdok-border);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(17,17,17,.45);
      font-weight: 800;
      text-align: center;
      padding: 24px;
    }

    #shopify-section-{{ section.id }} .pdok-compare-placeholder.pdok-compare-graphic-mobile {
      display: none;
    }

    /* FEATURE BLOCKS */
    #shopify-section-{{ section.id }} .pdok-feature {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      align-items: center;
      margin-top: 34px;
    }

    #shopify-section-{{ section.id }} .pdok-feature:nth-child(even) .pdok-feature-copy {
      order: 2;
    }

    #shopify-section-{{ section.id }} .pdok-feature-media {
      aspect-ratio: 3 / 2;
      min-height: 0;
      border-radius: 30px;
      overflow: hidden;
      border: 1px solid var(--pdok-border);
      background: #e9dfce;
    }

    #shopify-section-{{ section.id }} .pdok-feature-media img {
      width: 100%;
      height: 100%;
      display: block;
      object-fit: cover;
    }

    #shopify-section-{{ section.id }} .pdok-feature-copy {
      padding: 14px 0;
    }

    #shopify-section-{{ section.id }} .pdok-feature-copy .pdok-p {
      margin-top: 16px;
      max-width: 520px;
    }

    /* TRUST */
#shopify-section-{{ section.id }} .pdok-trust-section {
  background: #263d3e;
  color: #fff;
}

#shopify-section-{{ section.id }} .pdok-trust-section .pdok-h2,
#shopify-section-{{ section.id }} .pdok-trust-section .pdok-p,
#shopify-section-{{ section.id }} .pdok-trust-section .pdok-eyebrow {
  color: #fff;
}

#shopify-section-{{ section.id }} .pdok-trust-header {
  max-width: 980px;
}

#shopify-section-{{ section.id }} .pdok-trust-header .pdok-p {
  margin-top: 18px;
  max-width: 760px;
}

#shopify-section-{{ section.id }} .pdok-trust-section .pdok-review-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-top: 42px;
}

#shopify-section-{{ section.id }} .pdok-review {
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 24px;
  padding: 24px 28px;
  text-align: center;
  display: block !important;
  min-height: 0 !important;
  height: auto !important;
}

#shopify-section-{{ section.id }} .pdok-stars {
  color: #f7c948;
  display: block;
  text-align: center;
  letter-spacing: .12em;
  margin: 0;
  font-size: 28px;
  line-height: 1;
}

#shopify-section-{{ section.id }} .pdok-review {
  background: rgba(255,255,255,.1);
  border: 1px solid rgba(255,255,255,.16);
  border-radius: 24px;
  padding: 24px 28px;
  text-align: center;
  min-height: 155px !important;
  height: auto !important;
  display: grid !important;
  grid-template-rows: auto minmax(42px, auto) auto;
  align-content: center;
  row-gap: 14px;
}

#shopify-section-{{ section.id }} .pdok-review strong {
  display: block;
  margin: 0;
  padding: 0;
  color: #fff;
  font-size: 14px;
  text-align: center;
  align-self: end;
}
    /* INCLUDED/SPECS */
    #shopify-section-{{ section.id }} .pdok-two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      margin-top: 34px;
    }

    #shopify-section-{{ section.id }} .pdok-panel {
      background: #fff;
      border: 1px solid var(--pdok-border);
      border-radius: 22px;
      padding: 22px;
    }

    #shopify-section-{{ section.id }} .pdok-panel h3 {
      margin: 0 0 8px;
      font-size: 20px;
      line-height: 1.1;
    }

    #shopify-section-{{ section.id }} .pdok-panel p {
      margin: 0;
      color: var(--pdok-muted);
      font-size: 15px;
      line-height: 1.48;
    }

    #shopify-section-{{ section.id }} .pdok-list {
      list-style: none;
      margin: 18px 0 0;
      padding: 0;
      display: grid;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .pdok-list li {
      position: relative;
      padding-left: 28px;
      color: var(--pdok-muted);
      line-height: 1.45;
    }

    #shopify-section-{{ section.id }} .pdok-list li:before {
      content: "✓";
      position: absolute;
      left: 0;
      top: 0;
      color: #0f6b4f;
      font-weight: 900;
    }

    #shopify-section-{{ section.id }} .pdok-spec-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 18px;
    }

    #shopify-section-{{ section.id }} .pdok-spec {
      border: 1px solid rgba(17,17,17,.09);
      border-radius: 16px;
      padding: 14px;
      background: rgba(250, 244, 231, .7);
    }

    #shopify-section-{{ section.id }} .pdok-spec span {
      display: block;
      color: var(--pdok-muted);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .08em;
      margin-bottom: 4px;
      font-weight: 800;
    }

    #shopify-section-{{ section.id }} .pdok-spec strong {
      font-size: 16px;
    }

    /* BUY SECTION */
    #shopify-section-{{ section.id }} .pdok-buy {
      background: var(--pdok-card);
      border-top: 1px solid var(--pdok-border);
      border-bottom: 1px solid var(--pdok-border);
    }

    #shopify-section-{{ section.id }} .pdok-buy-grid {
      display: grid;
      grid-template-columns: .95fr 1.05fr;
      gap: 34px;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .pdok-buy-media {
      aspect-ratio: 4 / 3;
      min-height: 0;
      border-radius: 34px;
      overflow: hidden;
      border: 1px solid var(--pdok-border);
      background: #e9dfce;
    }

#shopify-section-{{ section.id }} .pdok-buy-media img {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

    #shopify-section-{{ section.id }} .pdok-price {
      display: flex;
      align-items: baseline;
      gap: 14px;
      flex-wrap: wrap;
      margin: 22px 0 14px;
    }

    #shopify-section-{{ section.id }} .pdok-price-current {
      font-size: 34px;
      font-weight: 900;
      letter-spacing: -.04em;
    }

    #shopify-section-{{ section.id }} .pdok-price-compare {
      color: var(--pdok-muted);
      text-decoration: line-through;
      font-size: 20px;
    }

    #shopify-section-{{ section.id }} .pdok-save {
      display: inline-flex;
      padding: 7px 10px;
      border-radius: 999px;
      background: var(--pdok-accent);
      color: #111;
      font-weight: 850;
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .pdok-buy-form {
      margin-top: 22px;
    }

    #shopify-section-{{ section.id }} .pdok-buy-form .pdok-btn {
      width: 100%;
      max-width: 360px;
    }

    #shopify-section-{{ section.id }} .pdok-microcopy {
      margin-top: 12px;
      color: var(--pdok-muted);
      font-size: 14px;
      line-height: 1.45;
    }

    /* FAQ */
    #shopify-section-{{ section.id }} .pdok-faq {
      max-width: 880px;
      margin: 34px auto 0;
      display: grid;
      gap: 12px;
    }

    #shopify-section-{{ section.id }} .pdok-faq details {
      background: #fff;
      border: 1px solid var(--pdok-border);
      border-radius: 18px;
      padding: 18px 20px;
    }

    #shopify-section-{{ section.id }} .pdok-faq summary {
      cursor: pointer;
      font-weight: 850;
      font-size: 17px;
      color: var(--pdok-ink);
    }

    #shopify-section-{{ section.id }} .pdok-faq p {
      margin: 12px 0 0;
      color: var(--pdok-muted);
      line-height: 1.55;
    }

    /* FINAL */
    #shopify-section-{{ section.id }} .pdok-final {
      text-align: center;
      background: #111;
      color: #fff;
    }

    #shopify-section-{{ section.id }} .pdok-final .pdok-h2,
    #shopify-section-{{ section.id }} .pdok-final .pdok-p {
      color: #fff;
      margin-left: auto;
      margin-right: auto;
    }

    #shopify-section-{{ section.id }} .pdok-final .pdok-p {
      max-width: 680px;
      margin-top: 18px;
      opacity: .88;
    }

    #shopify-section-{{ section.id }} .pdok-final .pdok-btn {
      margin-top: 28px;
    }

    @media (max-width: 900px) {
      #shopify-section-{{ section.id }} .pdok-section {
        padding: 54px 0;
      }

      #shopify-section-{{ section.id }} .pdok-hero {
        min-height: 680px;
      }

      #shopify-section-{{ section.id }} .pdok-hero-content {
        padding: 110px 0 38px;
      }

      #shopify-section-{{ section.id }} .pdok-use-grid,
      #shopify-section-{{ section.id }} .pdok-review-grid {
        grid-template-columns: 1fr 1fr;
      }

      #shopify-section-{{ section.id }} .pdok-feature,
      #shopify-section-{{ section.id }} .pdok-two-col,
      #shopify-section-{{ section.id }} .pdok-buy-grid {
        grid-template-columns: 1fr;
      }

      #shopify-section-{{ section.id }} .pdok-feature:nth-child(even) .pdok-feature-copy {
        order: initial;
      }

      #shopify-section-{{ section.id }} .pdok-feature-media {
        aspect-ratio: 3 / 2;
        min-height: 0;
      }

      #shopify-section-{{ section.id }} .pdok-buy-media {
        aspect-ratio: 4 / 3;
        min-height: 0;
      }
      #shopify-section-{{ section.id }} .pdok-hero-copy-mobile {
        display: none;
      }
    }

    @media (max-width: 640px) {
      #shopify-section-{{ section.id }} .pdok-container {
        padding: 0 16px;
      }

      #shopify-section-{{ section.id }} .pdok-section {
        padding: 54px 0;
      }

      /* MOBILE HERO */
      #shopify-section-{{ section.id }} .pdok-hero {
        min-height: 635px;
        align-items: flex-end;
      }

      #shopify-section-{{ section.id }} .pdok-hero-content {
        padding: 0 22px 26px;
      }

      #shopify-section-{{ section.id }} .pdok-hero-media .pdok-img {
        object-position: 64% center;
      }

#shopify-section-{{ section.id }} .pdok-hero-media:after {
  background:
    linear-gradient(180deg, rgba(0,0,0,.04) 0%, rgba(0,0,0,.02) 38%, rgba(0,0,0,.34) 62%, rgba(0,0,0,.82) 100%);
